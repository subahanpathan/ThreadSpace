generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  username  String    @unique
  password  String?   // hashed, nullable for OAuth users
  image     String?
  createdAt DateTime  @default(now())
  posts     Post[]
  comments  Comment[]
  votes     Vote[]
  subscriptions Community[] @relation("CommunitySubscription")
  moderatedCommunities Community[] @relation("CommunityModerator")
  savedPosts  Post[]    @relation("UserSavedPosts")
}

model Community {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  imageUrl    String?
  isNsfw      Boolean  @default(false)
  createdAt   DateTime @default(now())
  posts       Post[]
  subscribers User[] @relation("CommunitySubscription")
  moderators  User[]   @relation("CommunityModerator")
}

model Post {
  id          String    @id @default(cuid())
  title       String
  content     String?
  imageUrl    String?
  linkUrl     String?
  type        String    @default("text") // "text" | "image" | "link"
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  comments    Comment[]
  votes       Vote[]
  savedBy     User[]    @relation("UserSavedPosts")
  createdAt   DateTime  @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  parentId  String?
  parent    Comment? @relation("CommentParent", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentParent")
}

model Vote {
  id     String @id @default(cuid())
  type   String // "UP" | "DOWN"
  userId String
  user   User   @relation(fields: [userId], references: [id])
  postId String
  post   Post   @relation(fields: [postId], references: [id])

  @@unique([userId, postId]) // one vote per user per post
}


